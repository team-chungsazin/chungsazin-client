{
  "name": "chungsazin-client",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "pnpm lint && pnpm test && pnpm build",
    "lint": "biome check src .storybook package.json tsconfig.app.json tsconfig.json tsconfig.node.json vite.config.ts vitest.config.ts biome.json",
    "format": "biome format src .storybook package.json tsconfig.app.json tsconfig.json tsconfig.node.json vite.config.ts vitest.config.ts biome.json --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@storybook/addon-a11y": "8.6.15",
    "@storybook/addon-essentials": "8.6.15",
    "@storybook/addon-interactions": "8.6.15",
    "@storybook/react": "8.6.15",
    "@storybook/react-vite": "8.6.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.12",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.1.4",
    "@vitejs/plugin-react": "^5.1.3",
    "jsdom": "^28.0.0",
    "lefthook": "^2.1.0",
    "storybook": "8.6.15",
    "typescript": "~5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
